{
    "name": "dev-astro/laravel-query-filters",
    "description": "A simple and powerful query filtering system for Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "DevAstro\\LaravelQueryFilters\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevAstro\\LaravelQueryFilters\\LaravelQueryFiltersServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0"
    },
    "keywords": [
        "laravel",
        "filter",
        "eloquent",
        "query-filter",
        "request-filter",
        "api-filter"
    ]
}